# PostgreSQL password (used by both the postgres container and the service)
POSTGRES_PASSWORD=changeme

# Secret shared with the Laravel backend (METRICS_SERVICE_SECRET in hosting .env)
INGEST_SECRET=change-this-to-a-long-random-string

# Laravel backend URL and HMAC secret (for user/hosting suspension management)
# LARAVEL_URL must match the base URL of the Laravel backend (no trailing slash)
# HMAC_SECRET must match Laravel's HMAC_SECRET env var
LARAVEL_URL=https://api.example.com
HMAC_SECRET=change-this-to-a-long-random-string

# Admin panel first user — created on first boot if no admins exist yet
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-password
ADMIN_NAME=Admin

# Host port to expose (default 8080)
PORT=8080
